# Public base URL of the HOPS backend API.
# MUST point at the `/api/v1` prefix and MUST NOT carry a trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Build-time environment label. One of: development | staging | production.
# Surfaced for diagnostics only; runtime config is selected by Next.js
# based on `next dev` vs `next start`.
NEXT_PUBLIC_APP_ENV=development
